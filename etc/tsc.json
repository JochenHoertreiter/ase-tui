{
    "compilerOptions": {
        "outDir":                  "../dst",
        "target":                  "esnext",
        "module":                  "nodenext",
        "moduleResolution":        "nodenext",
        "useDefineForClassFields": true,
        "composite":               false,
        "strict":                  true,
        "resolveJsonModule":       true,
        "isolatedModules":         true,
        "esModuleInterop":         true,
        "jsx":                     "react-jsx",
        "jsxImportSource":         "react",
        "lib":                     [ "ESNext" ],
        "skipLibCheck":            true,
        "noEmit":                  false,
        "types":                   [ "node" ],
        "rootDir":                 "../src"
    },
    "include": [
        "../src/**/*.tsx",
        "../src/**/*.d.ts",
        "../package.json"
    ]
}
