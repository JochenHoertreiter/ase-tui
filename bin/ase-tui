#   resolve our own path
self="$0"
while [ -L "$self" ]; do
    target=$(readlink "$self")
    case "$target" in
        /* ) self="$target" ;;
        *  ) self="$(dirname "$self")/$target" ;;
    esac
done

#   resolve our base directory
basedir=$(cd "$(dirname "$self")" && pwd)

#   pass-through execution
exec node "$basedir/ase-tui.cjs" ${1+"$@"}

